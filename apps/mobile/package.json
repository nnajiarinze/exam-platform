{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.3.11",
    "@react-navigation/native-stack": "^7.18.3",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~54.0.0",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-hook-form": "^7.82.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.99.0",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "jest-expo": "~54.0.17",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "generate:api": "openapi-ts -i ../../contracts/openapi/learning-service-v1.yaml -o src/api/generated -c @hey-api/client-fetch",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "build": "expo export --platform android",
    "web": "expo start --web"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/src/test/setup.ts"
    ]
  }
}

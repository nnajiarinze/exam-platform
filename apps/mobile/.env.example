# One public gateway. Hosted builds use an HTTPS URL; no server secrets belong here.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8088
EXPO_PUBLIC_APP_ENV=development
# Legacy direct-service override for local development only.
EXPO_PUBLIC_LEARNING_BASE_URL=
# Development-only fallback. Leave empty when testing the OIDC login flow.
EXPO_PUBLIC_LEARNER_IDENTITY=dev-learner-001
EXPO_PUBLIC_EXAM_ID=swedish-citizenship
EXPO_PUBLIC_OIDC_ISSUER=http://localhost:8090/realms/exam-platform
EXPO_PUBLIC_OIDC_CLIENT_ID=mobile-app
EXPO_PUBLIC_PRIVACY_URL=
EXPO_PUBLIC_TERMS_URL=
EXPO_PUBLIC_HELP_URL=
# For a physical phone, replace localhost in both base URLs with the development
# machine's LAN IP and start Compose with OIDC_PUBLIC_BASE_URL set to that URL.

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exam-platform.local/contracts/content-snapshot-v1.schema.json",
  "title": "Published content snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "externalReleaseId", "examId", "examVersionId", "releaseVersion", "releaseStatus", "publishedAt", "checksum", "subjects"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "externalReleaseId": { "type": "string", "minLength": 1 },
    "examId": { "type": "string", "minLength": 1 },
    "examVersionId": { "type": "string", "minLength": 1 },
    "releaseVersion": { "type": "string", "minLength": 1 },
    "releaseStatus": { "const": "PUBLISHED" },
    "publishedAt": { "type": "string", "format": "date-time" },
    "checksum": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "subjects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "sortOrder", "topics"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "sortOrder": { "type": "integer", "minimum": 0 },
          "topics": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "name", "sortOrder", "questions"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "name": { "type": "string", "minLength": 1 },
                "description": { "type": ["string", "null"] },
                "sortOrder": { "type": "integer", "minimum": 0 },
                "questions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["id", "versionId", "knowledgeFactId", "questionType", "prompt", "explanation", "language", "active", "answerOptions"],
                    "properties": {
                      "id": { "type": "string", "minLength": 1 },
                      "versionId": { "type": "string", "minLength": 1 },
                      "knowledgeFactId": { "type": "string", "minLength": 1 },
                      "questionType": { "const": "SINGLE_CHOICE" },
                      "prompt": { "type": "string", "minLength": 1 },
                      "explanation": { "type": "string", "minLength": 1 },
                      "language": { "type": "string", "minLength": 2 },
                      "difficulty": { "type": ["string", "null"] },
                      "active": { "type": "boolean" },
                      "answerOptions": {
                        "type": "array",
                        "minItems": 2,
                        "items": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": ["id", "text", "correct", "sortOrder"],
                          "properties": {
                            "id": { "type": "string", "minLength": 1 },
                            "text": { "type": "string", "minLength": 1 },
                            "correct": { "type": "boolean" },
                            "sortOrder": { "type": "integer", "minimum": 0 }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "description": "SHA-256 checksum is calculated over canonical JSON serialization of the snapshot with the checksum field omitted. Object field order follows this schema and array order is significant."
}

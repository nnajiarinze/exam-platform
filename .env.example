# Profiles and public URLs
SPRING_PROFILES_ACTIVE=hosted
PUBLIC_API_BASE_URL=https://api.example.com
PUBLIC_WEB_URL=https://admin.example.com
MOBILE_DEEP_LINK_BASE_URL=sveastudy://
CORS_ALLOWED_ORIGINS=https://admin.example.com

# Content Service database (server secrets except pool tuning)
CONTENT_DATABASE_URL=jdbc:postgresql://HOST:5432/content?sslmode=verify-full
CONTENT_DATABASE_USERNAME=
CONTENT_DATABASE_PASSWORD=
CONTENT_DB_MAX_POOL_SIZE=5

# Learning Service database
LEARNING_DATABASE_URL=jdbc:postgresql://HOST:5432/learning?sslmode=verify-full
LEARNING_DATABASE_USERNAME=
LEARNING_DATABASE_PASSWORD=
LEARNING_DB_MAX_POOL_SIZE=5

# AI Service database
AI_DATABASE_URL=jdbc:postgresql://HOST:5432/ai?sslmode=verify-full
AI_DATABASE_USERNAME=
AI_DATABASE_PASSWORD=
AI_DB_MAX_POOL_SIZE=4

# Identity database
KC_DB_URL=jdbc:postgresql://HOST:5432/identity?sslmode=verify-full
KC_DB_USERNAME=
KC_DB_PASSWORD=
KC_HOSTNAME=https://api.example.com/auth
KC_BOOTSTRAP_ADMIN_USERNAME=
KC_BOOTSTRAP_ADMIN_PASSWORD=

# Private services and authentication
CONTENT_SERVICE_BASE_URL=
LEARNING_SERVICE_BASE_URL=
AI_SERVICE_BASE_URL=
OIDC_ISSUER_URI=https://api.example.com/auth/realms/exam-platform
OIDC_JWK_SET_URI=
LEARNING_INTERNAL_API_KEY=
AI_INTERNAL_API_KEY=

# Gemini
AI_PROVIDER=GEMINI
AI_GEMINI_API_KEY=
AI_GEMINI_MODEL=

# Transactional email
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Svea Study
RESEND_REPLY_TO_EMAIL=
RESEND_API_BASE_URL=https://api.resend.com
RESEND_TIMEOUT=10s
RESEND_MAX_RETRIES=2

# Public client build-time values (never put secrets here)
EXPO_PUBLIC_APP_ENV=production
EXPO_PUBLIC_API_BASE_URL=https://api.example.com
EXPO_PUBLIC_OIDC_ISSUER=https://api.example.com/auth/realms/exam-platform
VITE_API_BASE_URL=https://api.example.com
VITE_OIDC_AUTHORITY=https://api.example.com/auth/realms/exam-platform
